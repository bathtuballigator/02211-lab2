defproc sdt_sink <: sink ()
+{
  syn::sdtvar<8> x;
  syn::sdtchan<8> y;
}
{
 refine {
   syn::muxinport<8,1> y_muxi(y);
   syn::var_int_in_ports<8,1> var_x(x);
   a1of1 c0;
   syn::trueto1of2 e0;
   a1of1 c1;
   a1of1 c2;
   syn::recvport<8,8> s_0(c2,y_muxi.m[0],var_x.in[0]);   a1of1 c3;
   syn::sskip s_1(c3);
   syn::semi<2> s_2(c1,{c2,c3});
   syn::loop<1> s_3(c0,{e0.out},{c1});
/*--- connect reset to go signal ---*/
   a1of1 c4;
   syn::sinit s4 (c0);
 }
}

