  syn::expr::nullint<1> e6(var_fvar0.out[0]);
   syn::bdto1of2 e7;
   e7.out.r = c4.r; c4.a = e6.out.r; e7.out.d=e6.out.d; e7.out.a=e6.out.a;
   a1of1 c5;
